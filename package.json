{
    "name": "js-vtt",
    "version": "2.1.0",
    "description": "A JavaScript library for parsing and manipulating WebVTT files.",
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/main.ts",
        "build": "tsdown",
        "preview": "vite preview",
        "test": "vitest --coverage",
        "lint": "eslint .",
        "format": "prettier --write .",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:serve": "vitepress serve docs",
        "changeset": "changeset",
        "version": "changeset version",
        "release": "changeset publish"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        },
        "./segments/*": {
            "types": "./dist/segments/*.d.mts",
            "import": "./dist/segments/*.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.5.0",
        "@vitest/coverage-v8": "^4.1.2",
        "c8": "^7.14.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.1",
        "tsdown": "^0.21.7",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0",
        "vite": "^8.0.3",
        "vitepress": "^1.6.4",
        "vitest": "^4.1.2",
        "vue": "^3.5.31"
    }
}
